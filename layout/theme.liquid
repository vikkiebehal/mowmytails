<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#3F6F64">
    <link rel="canonical" href="{{ canonical_url }}">
    <title>{{ page_title }}{% unless page_title contains shop.name %} | {{ shop.name }}{% endunless %}</title>
    {% if page_description %}<meta name="description" content="{{ page_description | escape }}">{% endif %}
    {{ 'mowmy-theme.css' | asset_url | stylesheet_tag }}
    {{ content_for_header }}
  </head>
  <body class="template-{{ template.name | handle }}">
    <a class="skip-link" href="#MainContent">Skip to content</a>
    {% section 'mowmy-announcement-bar' %}
    {% section 'mowmy-header' %}
    <main id="MainContent" tabindex="-1">{{ content_for_layout }}</main>
    {% section 'mowmy-footer' %}
    {% render 'cart-drawer' %}
    {% render 'search-overlay' %}
    <div class="mt-toast" data-toast role="status" aria-live="polite"></div>
    <script src="{{ 'mowmy-theme.js' | asset_url }}" defer></script>
  </body>
</html>
