<section><div class="mt-page-hero"><div class="mt-page"><span class="mt-eyebrow">Helpful answers</span><h1>{{ section.settings.heading }}</h1><p>{{ section.settings.text }}</p></div></div><div class="mt-page mt-section"><div class="mt-faq-wrap mt-accordion">{% for block in section.blocks %}<details {% if forloop.first %}open{% endif %} {{ block.shopify_attributes }}><summary>{{ block.settings.question }}</summary><div class="mt-accordion__content">{{ block.settings.answer }}</div></details>{% endfor %}</div></div></section>
{% schema %}{"name":"FAQ page","settings":[{"type":"text","id":"heading","label":"Heading","default":"Frequently Asked Questions"},{"type":"textarea","id":"text","label":"Text","default":"Everything you need to know about orders, sizing, delivery and caring for your pet's new favorites."}],"blocks":[{"type":"faq","name":"Question","settings":[{"type":"text","id":"question","label":"Question","default":"How long does shipping take?"},{"type":"textarea","id":"answer","label":"Answer","default":"Orders are generally dispatched within 1–3 business days. Delivery timing depends on your location and is shown at checkout when available."}]}],"presets":[{"name":"FAQ page","blocks":[{"type":"faq"},{"type":"faq","settings":{"question":"What is your return policy?","answer":"Eligible unused items can be returned within the stated return window. Please keep original tags and packaging intact."}},{"type":"faq","settings":{"question":"How do I choose the right size?","answer":"Measure your pet's neck, widest chest point and back length. Compare those measurements with the product size guide and size up when between sizes."}},{"type":"faq","settings":{"question":"Can I change or cancel my order?","answer":"Contact us as soon as possible. We will do our best to help before the order enters packing or dispatch."}},{"type":"faq","settings":{"question":"How should I care for apparel and beds?","answer":"Always follow the product care label. Gentle cold washing and air drying are recommended for many soft goods."}}]}]}{% endschema %}
