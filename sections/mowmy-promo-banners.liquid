<section class="mt-section mt-reveal"><div class="mt-page"><div class="mt-section-head"><span class="mt-eyebrow">{{ section.settings.eyebrow }}</span><h2 class="mt-title">{{ section.settings.heading }}</h2></div><div class="mt-promo-grid">{% for block in section.blocks %}<a class="mt-promo-card" href="{{ block.settings.link }}" {{ block.shopify_attributes }}>{% if block.settings.image %}{{ block.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', alt: block.settings.title }}{% else %}{% case forloop.index %}{% when 1 %}<img src="{{ 'mt-photo-walk-essentials.jpg' | asset_url }}" width="1200" height="900" alt="Dog wearing walk ready essentials" loading="lazy">{% when 2 %}<img src="{{ 'mt-photo-cozy-beds.jpg' | asset_url }}" width="1200" height="900" alt="Dog resting on a cozy bed" loading="lazy">{% else %}<img src="{{ 'mt-photo-toys-play.jpg' | asset_url }}" width="1200" height="900" alt="Pet playing with enriching toys" loading="lazy">{% endcase %}{% endif %}<div class="mt-promo-card__copy"><h3>{{ block.settings.title }}</h3><p>{{ block.settings.text }}</p><span class="mt-btn mt-btn--small mt-btn--primary">{{ block.settings.label }}</span></div></a>{% endfor %}</div></div></section>
{% schema %}{"name":"Promo banners","settings":[{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Everyday favorites"},{"type":"text","id":"heading","label":"Heading","default":"Good days start with the right essentials"}],"blocks":[{"type":"banner","name":"Promo banner","settings":[{"type":"image_picker","id":"image","label":"Image"},{"type":"text","id":"title","label":"Title","default":"Walk Ready Essentials"},{"type":"textarea","id":"text","label":"Text","default":"Comfortable gear for every adventure."},{"type":"text","id":"label","label":"Button label","default":"Shop now"},{"type":"url","id":"link","label":"Link"}]}],"presets":[{"name":"Promo banners","blocks":[{"type":"banner","settings":{"title":"Walk Ready Essentials"}},{"type":"banner","settings":{"title":"Cozy Beds for Better Sleep"}},{"type":"banner","settings":{"title":"Toys That Keep Them Busy"}}]}]}{% endschema %}
