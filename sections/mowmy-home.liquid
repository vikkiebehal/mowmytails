  </div>
</section>
<section class='mt-section'><div class='mt-page'><div class='mt-section-head'><h2 class='mt-title mt-serif'><span class='mark'>✤</span> Shop by Collection</h2></div><div class='mt-collections'><a class='mt-collection' href='/collections/all'><h3 class='mt-serif'>Summer<br>Fits</h3><span>SHOP NOW ›</span><div class='emoji'>🌴</div></a><a class='mt-collection' href='/collections/all'><h3 class='mt-serif'>Harness<br>Sets</h3><span>SHOP NOW ›</span><div class='emoji'>🦮</div></a><a class='mt-collection' href='/collections/all'><h3 class='mt-serif'>Cozy<br>Corners</h3><span>SHOP NOW ›</span><div class='emoji'>🛏️</div></a><a class='mt-collection' href='/collections/all'><h3 class='mt-serif'>Twinning<br>Looks</h3><span>SHOP NOW ›</span><div class='emoji'>💜</div></a></div></div></section>
<section class='mt-section'><div class='mt-page'><div class='mt-section-head'><h2 class='mt-title mt-serif'>Bestsellers ♡</h2><a class='mt-view' href='/collections/all'>VIEW ALL PRODUCTS ›</a></div><div class='mt-products'>{% assign featured_collection = collections[section.settings.collection] %}{% if featured_collection != blank and featured_collection.products_count > 0 %}{% for product in featured_collection.products limit: 4 %}<a class='mt-product' href='{{ product.url }}'><div class='mt-product-emoji'>{% if product.featured_image %}{{ product.featured_image | image_url: width: 340 | image_tag: loading: 'lazy', alt: product.title }}{% else %}🐾{% endif %}</div><h3>{{ product.title }}</h3><div class='mt-price'>{{ product.price | money }}{% if product.compare_at_price > product.price %}<s>{{ product.compare_at_price | money }}</s>{% endif %}</div><div class='mt-stars'>★★★★★</div><span class='mt-add'>Add to Cart</span></a>{% endfor %}{% else %}<div class='mt-product'><div class='mt-product-emoji'>🎽</div><h3>Aqua Adventure Harness Set</h3><div class='mt-price'>₹1,899 <s>₹2,499</s></div><div class='mt-stars'>★★★★★</div><span class='mt-add'>Add to Cart</span></div><div class='mt-product'><div class='mt-product-emoji'>🔷</div><h3>Lick You Bandana</h3><div class='mt-price'>₹499 <s>₹699</s></div><div class='mt-stars'>★★★★★</div><span class='mt-add'>Add to Cart</span></div><div class='mt-product'><div class='mt-product-emoji'>🩷</div><h3>Pretty in Pink Leash</h3><div class='mt-price'>₹899 <s>₹1,199</s></div><div class='mt-stars'>★★★★★</div><span class='mt-add'>Add to Cart</span></div><div class='mt-product'><div class='mt-product-emoji'>☁️</div><h3>Lilac Cloud Donut Bed</h3><div class='mt-price'>₹1,799 <s>₹2,299</s></div><div class='mt-stars'>★★★★★</div><span class='mt-add'>Add to Cart</span></div>{% endif %}</div></div></section>
<section class='mt-section'><div class='mt-page'><div class='mt-section-head'><h2 class='mt-title mt-serif'>Seen on Happy Tails.</h2><a class='mt-view' href='/'>FOLLOW @MOWMYTAILS</a></div><div class='mt-ugc'><div class='mt-ugc-card'>🐶</div><div class='mt-ugc-card'>🐱</div><div class='mt-ugc-card'>🦮</div><div class='mt-ugc-card'>🎽</div><div class='mt-ugc-card'>💜</div><div class='mt-ugc-card'>🛏️</div><div class='mt-ugc-card'>🌴</div><div class='mt-ugc-card'>🐾</div></div></div></section>
<section class='mt-page'><div class='mt-promise'><div class='mt-promise-item'><div class='mt-icon'>🛡️</div><div><h3>Premium Quality</h3><p>Thoughtfully sourced, built to last.</p></div></div><div class='mt-promise-item'><div class='mt-icon'>🌿</div><div><h3>Pet-Safe Materials</h3><p>Non-toxic, durable and completely safe.</p></div></div><div class='mt-promise-item'><div class='mt-icon'>🚚</div><div><h3>Fast & Reliable</h3><p>Quick deliveries across India.</p></div></div><div class='mt-promise-item'><div class='mt-icon'>💗</div><div><h3>Made with Love</h3><p>Because every tail deserves the best.</p></div></div></div></section>
