    </div>
    <form>
      <input type="email" placeholder="Enter your email" required aria-label="Email Address">
      <button type="button">Join Community</button>
    </form>
  </section>
</section>

<style>
.mowmy-home-v2 {
  --bg-primary: #FAF6F0;
  --bg-secondary: #FFFDFB;
  --text-main: #2D1F17;
  --text-muted: #6E5E53;
  --accent-color: #B88E4F;
  --accent-dark: #8E652E;
  --border-color: #EADFD3;
  --border-color-dark: #D4C3B2;
  --radius-lg: 20px;
  --radius-md: 12px;
  --transition-smooth: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  --shadow-subtle: 0 10px 35px rgba(45, 31, 23, 0.03);
  --shadow-hover: 0 18px 45px rgba(45, 31, 23, 0.08);
  background: var(--bg-primary);
  color: var(--text-main);
  overflow-x: hidden;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}
.mowmy-home-v2 * { box-sizing: border-box; }

/* Mowmy circular category section */
.mowmy-circle-category {
  background: #fffdf8;
  padding: 64px 0 58px;
  border-bottom: 1px solid rgba(180, 142, 79, 0.13);
}

.mowmy-circle-category__inner {
  width: min(1200px, calc(100% - 48px));
  margin: 0 auto;
  text-align: center;
}

.mowmy-circle-category__head {
  margin-bottom: 34px;
}

.mowmy-circle-category__head p {
  margin: 0 0 10px;
  color: var(--accent-color);
  text-transform: uppercase;
  letter-spacing: 0.16em;
  font-size: 11px;
  font-weight: 800;
}

.mowmy-circle-category__head h3 {
  margin: 0;
  color: var(--text-main);
  font-family: "Playfair Display", Georgia, serif;
  font-size: clamp(30px, 4vw, 44px);
  font-weight: 400;
  line-height: 1.15;
}

.mowmy-circle-category__grid {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 26px;
  align-items: start;
}

.mowmy-circle-category__item {
  text-decoration: none;
  color: var(--text-main);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14px;
  transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
}

.mowmy-circle-category__item:hover {
  transform: translateY(-6px);
}

.mowmy-circle-category__image {
  width: 168px;
  height: 168px;
  border-radius: 50%;
  padding: 7px;
  background: #fff9f0;
  border: 2px solid rgba(184, 142, 79, 0.42);
  box-shadow: 0 16px 34px rgba(45, 31, 23, 0.08);
  overflow: hidden;
  transition: box-shadow 0.35s ease, border-color 0.35s ease;
}

.mowmy-circle-category__item:hover .mowmy-circle-category__image {
  border-color: var(--accent-color);
  box-shadow: 0 22px 46px rgba(45, 31, 23, 0.13);
}

.mowmy-circle-category__image img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  object-fit: cover;
  display: block;
  transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
}

.mowmy-circle-category__item:hover img {
  transform: scale(1.07);
}

.mowmy-circle-category__fallback {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 25%, #f3e3cf 0 18%, transparent 19%), #faf6f0;
  color: var(--accent-dark);
  display: grid;
  place-items: center;
  font-size: 13px;
  font-weight: 800;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.mowmy-circle-category__item span {
  color: var(--text-main);
  font-size: 22px;
  font-weight: 700;
  font-family: "Playfair Display", Georgia, serif;
  line-height: 1;
}

@media (max-width: 990px) {
  .mowmy-circle-category__grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px 18px;
  }

  .mowmy-circle-category__image {
    width: 148px;
    height: 148px;
  }
}

@media (max-width: 640px) {
  .mowmy-circle-category {
    padding: 44px 0 42px;
  }

  .mowmy-circle-category__inner {
    width: 100%;
    padding-left: 16px;
  }

  .mowmy-circle-category__head {
    padding-right: 16px;
    margin-bottom: 26px;
  }

  .mowmy-circle-category__grid {
    display: flex;
    gap: 18px;
    overflow-x: auto;
    padding: 2px 16px 12px 0;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
  }

  .mowmy-circle-category__grid::-webkit-scrollbar {
    display: none;
  }

  .mowmy-circle-category__item {
    min-width: 128px;
    scroll-snap-align: start;
  }

  .mowmy-circle-category__image {
    width: 118px;
    height: 118px;
    padding: 5px;
  }

  .mowmy-circle-category__item span {
    font-size: 18px;
  }
}

.mowmy-wrap-v2 { width: min(1200px, calc(100% - 48px)); margin: 0 auto; padding: 80px 0; }
.mowmy-eyebrow, .mowmy-section-title-v2 p, .mowmy-newsletter-v2 p { margin: 0 0 12px; color: var(--accent-color); text-transform: uppercase; letter-spacing: 0.15em; font-size: 11px; font-weight: 700; }
.mowmy-section-title-v2 h3 { margin: 0; font-size: clamp(26px, 3.2vw, 36px); font-family: "Playfair Display", Georgia, serif; font-weight: 400; line-height: 1.2; color: var(--text-main); letter-spacing: -0.01em; }
.mowmy-title-row { display: flex; align-items: flex-end; justify-content: space-between; gap: 24px; margin-bottom: 32px; }
.mowmy-view-all, .mowmy-text-link { color: var(--text-main); text-decoration: none; font-weight: 600; font-size: 13px; text-transform: uppercase; letter-spacing: 0.08em; position: relative; padding-bottom: 4px; transition: var(--transition-smooth); display: inline-flex; align-items: center; }
.mowmy-view-all::after, .mowmy-text-link::after { content: ""; position: absolute; bottom: 0; left: 0; width: 100%; height: 1px; background: var(--accent-color); transition: var(--transition-smooth); transform-origin: right; transform: scaleX(1); }
.mowmy-view-all:hover::after, .mowmy-text-link:hover::after { transform: scaleX(0); }
.mowmy-view-all:hover, .mowmy-text-link:hover { color: var(--accent-color); }
.mowmy-hero-v2 { min-height: 720px; display: grid; grid-template-columns: 52% 48%; background: linear-gradient(135deg, #FAF6F0 0%, #F3E8DA 100%); border-bottom: 1px solid var(--border-color); }
.mowmy-hero-v2__content { padding: 80px 56px 80px 8%; display: flex; flex-direction: column; justify-content: center; align-items: flex-start; text-align: left; }
.mowmy-hero-v2 h1 { max-width: 660px; margin: 0; font-family: "Playfair Display", Georgia, serif; font-size: clamp(48px, 5.4vw, 76px); font-weight: 600; line-height: 0.98; letter-spacing: -0.04em; text-transform: uppercase; color: var(--text-main); }
.mowmy-hero-v2__equals { display: inline-block; color: var(--accent-dark); font-style: italic; font-weight: 400; }
.mowmy-hero-v2 h2 { max-width: 540px; margin: 24px 0 16px; font-family: "Playfair Display", Georgia, serif; font-style: italic; font-weight: 400; font-size: clamp(22px, 2.4vw, 32px); color: var(--accent-dark); line-height: 1.2; }
.mowmy-hero-v2__text { max-width: 540px; margin: 0 0 30px; color: var(--text-muted); font-size: 15px; line-height: 1.75; }
.mowmy-hero-v2__buttons { display: flex; gap: 16px; flex-wrap: wrap; }
.mowmy-btn-v2 { height: 52px; padding: 0 32px; border-radius: 8px; display: inline-flex; align-items: center; justify-content: center; text-decoration: none; font-weight: 600; font-size: 13px; letter-spacing: 0.05em; text-transform: uppercase; transition: var(--transition-smooth); }
.mowmy-btn-v2--dark { background: var(--text-main); color: var(--bg-secondary); border: 1px solid var(--text-main); }
.mowmy-btn-v2--dark:hover { background: var(--accent-color); border-color: var(--accent-color); transform: translateY(-2px); }
.mowmy-btn-v2--light { background: transparent; color: var(--text-main); border: 1px solid var(--border-color-dark); }
