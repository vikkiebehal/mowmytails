      "settings": [
        { "type": "image_picker", "id": "image", "label": "Card image" },
        { "type": "text", "id": "image_alt", "label": "Image alt text" }
      ]
    }
  ],
  "presets": [
    { "name": "Mowmy Premium Home" }
  ]
}
