<script>
(function() {
  var track = document.getElementById('mowmyCategoryTrack');
  if (!track) return;
  var prevBtn = document.querySelector('.mowmy-arrow--prev');
  var nextBtn = document.querySelector('.mowmy-arrow--next');
  var currentIndex = 0;
  function getVisible() {
    if (window.innerWidth <= 640) return 1;
    if (window.innerWidth <= 990) return 2;
    return 4;
  }
  function getCards() { return track.querySelectorAll('.mowmy-slider-card'); }
  function updateSlider() {
    var cards = getCards();
    var visible = getVisible();
    var max = Math.max(0, cards.length - visible);
    currentIndex = Math.min(currentIndex, max);
    if (!cards.length) return;
    var cardWidth = cards[0].getBoundingClientRect().width;
    track.style.transform = 'translateX(-' + (currentIndex * (cardWidth + 20)) + 'px)';
    if (prevBtn) prevBtn.disabled = currentIndex === 0;
    if (nextBtn) nextBtn.disabled = currentIndex >= max;
  }
  if (prevBtn) prevBtn.addEventListener('click', function() { currentIndex = Math.max(0, currentIndex - 1); updateSlider(); });
  if (nextBtn) nextBtn.addEventListener('click', function() {
    var max = Math.max(0, getCards().length - getVisible());
    currentIndex = Math.min(max, currentIndex + 1); updateSlider();
  });
  var startX = 0;
  track.addEventListener('touchstart', function(e) { startX = e.touches[0].clientX; }, { passive: true });
  track.addEventListener('touchend', function(e) {
    var diff = startX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 50) {
      var max = Math.max(0, getCards().length - getVisible());
      currentIndex = diff > 0 ? Math.min(max, currentIndex + 1) : Math.max(0, currentIndex - 1);
      updateSlider();
    }
  }, { passive: true });
  window.addEventListener('resize', updateSlider);
  updateSlider();
})();
</script>
