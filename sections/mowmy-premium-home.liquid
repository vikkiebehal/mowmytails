{% liquid
  assign featured_collection = section.settings.featured_collection
%}

<section class="mowmy-home-v2">
  <!-- Hero Section -->
  <section class="mowmy-hero-v2">
    <div class="mowmy-hero-v2__content">
      <p class="mowmy-eyebrow">Bowl of Love Promise</p>
      <h1>1 Purchase <span class="mowmy-hero-v2__equals">=</span> 1 Bowl of Love</h1>
      <h2>Every order helps feed one street animal in need.</h2>
      <p class="mowmy-hero-v2__text">Premium pet essentials crafted with love — and every purchase helps us share a bowl of food with animals who need it most.</p>
      <div class="mowmy-hero-v2__buttons">
        <a href="{{ section.settings.primary_link | default: routes.all_products_collection_url }}" class="mowmy-btn-v2 mowmy-btn-v2--dark">Shop Dogs</a>
        <a href="{{ section.settings.secondary_link | default: routes.all_products_collection_url }}" class="mowmy-btn-v2 mowmy-btn-v2--light">Shop Cats</a>
      </div>
      <div class="mowmy-trust-row" aria-label="How the Bowl of Love promise works"><span>You Shop</span><span>We Serve</span><span>They Eat</span></div>
    </div>
    <div class="mowmy-hero-v2__image">
      {% if section.settings.hero_image != blank %}
        <img src="{{ section.settings.hero_image | image_url: width: 1400 }}" alt="Mowmy Tails premium pet lifestyle" width="1400" height="1100" loading="eager">
      {% else %}
        <div class="mowmy-placeholder-large">MT</div>
      {% endif %}
      <span class="mowmy-hero-v2__badge">Made with love in India</span>
    </div>
  </section>

  <!-- Shop By Category Circle Section -->
<section class="mowmy-circle-category">
  <div class="mowmy-circle-category__inner">
    <div class="mowmy-circle-category__head">
      <div class="mowmy-shop-category__head">
        <h2 class="mowmy-shop-category__title">Shop by Category</h2>
        <span>Thoughtfully curated for strolls, style, snuggles and everyday care</span>
      </div>
    </div>

    <div class="mowmy-circle-category__grid">
      <a href="{{ section.settings.circle_walk_link | default: '/collections/harnesses' }}" class="mowmy-circle-category__item">
        <div class="mowmy-circle-category__image">
          {% if section.settings.circle_walk_image != blank %}
            <img src="{{ section.settings.circle_walk_image | image_url: width: 500 }}" alt="Stroll" width="500" height="500" loading="lazy">
          {% else %}
            <div class="mowmy-circle-category__fallback">Stroll</div>
          {% endif %}
        </div>
        <span>Stroll</span>
      </a>

      <a href="{{ section.settings.circle_wear_link | default: '/collections/dog-apparel' }}" class="mowmy-circle-category__item">
        <div class="mowmy-circle-category__image">
          {% if section.settings.circle_wear_image != blank %}
            <img src="{{ section.settings.circle_wear_image | image_url: width: 500 }}" alt="Style" width="500" height="500" loading="lazy">
          {% else %}
            <div class="mowmy-circle-category__fallback">Style</div>
          {% endif %}
        </div>
        <span>Style</span>
      </a>

      <a href="{{ section.settings.circle_comfort_link | default: '/collections/snuggle' }}" class="mowmy-circle-category__item">
        <div class="mowmy-circle-category__image">
          {% if section.settings.circle_comfort_image != blank %}
            <img src="{{ section.settings.circle_comfort_image | image_url: width: 500 }}" alt="Snuggle" width="500" height="500" loading="lazy">
          {% else %}
            <div class="mowmy-circle-category__fallback">Snuggle</div>
          {% endif %}
        </div>
        <span>Snuggle</span>
      </a>

      <a href="{{ section.settings.circle_play_link | default: '/collections/toys' }}" class="mowmy-circle-category__item">
        <div class="mowmy-circle-category__image">
          {% if section.settings.circle_play_image != blank %}
            <img src="{{ section.settings.circle_play_image | image_url: width: 500 }}" alt="Fun" width="500" height="500" loading="lazy">
          {% else %}
            <div class="mowmy-circle-category__fallback">Fun</div>
          {% endif %}
        </div>
        <span>Fun</span>
      </a>

      <a href="{{ section.settings.circle_essentials_link | default: '/collections/accessories' }}" class="mowmy-circle-category__item">
        <div class="mowmy-circle-category__image">
          {% if section.settings.circle_essentials_image != blank %}
            <img src="{{ section.settings.circle_essentials_image | image_url: width: 500 }}" alt="Care" width="500" height="500" loading="lazy">
          {% else %}
            <div class="mowmy-circle-category__fallback">Care</div>
          {% endif %}
        </div>
        <span>Care</span>
      </a>
    </div>
  </div>
  </section>

  <!-- Shop By Category Section - Thunder Inspired Animated Slider -->
<section class="mowmy-tt-featured">
  <div class="mowmy-tt-head">
    <h3>Featured Collections</h3>
    <span>Curated picks for pets who deserve a little extra love</span>
  </div>

  <div class="mowmy-tt-slider-wrap">
    <button class="mowmy-arrow mowmy-arrow--prev" aria-label="Previous">&#8249;</button>

    <div class="mowmy-slider-viewport">
      <div class="mowmy-slider-track" id="mowmyCategoryTrack">
        {% for block in section.blocks %}
          {% if block.type == 'category' %}
            <a href="{{ block.settings.link | default: routes.all_products_collection_url }}" class="mowmy-slider-card" {{ block.shopify_attributes }}>
              <div class="mowmy-slider-card__inner">
                <div class="mowmy-slider-card__image">
                  {% if block.settings.image != blank %}
                    <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.title | escape }}" width="800" height="700" loading="lazy">
                  {% else %}
                    <div class="mowmy-pattern-v2"><span>MT</span></div>
                  {% endif %}
                </div>

                <div class="mowmy-slider-card__text">
                  <h4>{{ block.settings.title }}</h4>
                  <p>{{ block.settings.text }}</p>
                  <span class="mowmy-shop-now">
                    <span>SHOP NOW</span>
                    <span class="mowmy-btn-arrow">→</span>
                  </span>
                </div>
              </div>
            </a>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    <button class="mowmy-arrow mowmy-arrow--next" aria-label="Next">&#8250;</button>
  </div>
</section>

  <!-- Best Sellers Product Grid -->
  <section class="mowmy-wrap-v2 mowmy-products-v2">
    <div class="mowmy-section-title-v2 mowmy-title-row">
      <div>
        <p>Best sellers</p>
        <h3>Most loved by pet parents</h3>
      </div>
      <a href="/collections/homepage-picks" class="mowmy-view-all">Shop best sellers</a>
    </div>
    <div class="mowmy-product-grid-v2">
      {% if featured_collection != blank and featured_collection.products_count > 0 %}
        {% for product in featured_collection.products limit: 8 %}
          <a href="{{ product.url }}" class="mowmy-product-card-v2">
            <div class="mowmy-product-card-v2__image">
              {% if product.featured_image != blank %}
                <img src="{{ product.featured_image | image_url: width: 700 }}" alt="{{ product.title | escape }}" width="700" height="700" loading="lazy">
              {% else %}
                <div class="mowmy-pattern-v2"><span>MT</span></div>
              {% endif %}
              <em>♡</em>
            </div>
            <div class="mowmy-product-card-v2__info">
              <h4>{{ product.title }}</h4>
              <p>{{ product.price | money }}</p>
            </div>
          </a>
        {% endfor %}
      {% else %}
        {% for i in (1..8) %}
          <div class="mowmy-product-card-v2">
            <div class="mowmy-product-card-v2__image">
              <div class="mowmy-pattern-v2"><span>MT</span></div>
              <em>♡</em>
            </div>
            <div class="mowmy-product-card-v2__info">
              <h4>Product coming soon</h4>
              <p>₹999</p>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </section>

  {% comment %} ===== MOWMY FEATURE BANNER / WHY CHOOSE MOWMY ===== {% endcomment %}

<style>
  .mowmy-feature-banner {
  background-color: #FFFDF8;
  padding-top: 48px;
  padding-bottom: 48px;
  width: 100%;
  max-width: 100%;
  overflow: hidden;
  box-sizing: border-box;
}

  .mowmy-feature-banner__inner {
  max-width: 1200px;
  width: 100%;
  margin: 0 auto;
  padding: 0 16px;
  box-sizing: border-box;
  overflow: hidden;
}

  .mowmy-feature-banner__heading-wrap {
    text-align: center;
    margin-bottom: 40px;
  }

  .mowmy-feature-banner__label {
    display: block;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #A07840;
    margin-bottom: 10px;
  }

  .mowmy-feature-banner__title {
    font-size: 28px;
    font-weight: 600;
    color: #3B2A1A;
    margin: 0;
    line-height: 1.3;
  }

  .mowmy-feature-banner__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 28px;
    justify-items: center;
  }

  .mowmy-feature-banner__card {
    background-color: #FFFFFF;
    border-radius: 16px;
    box-shadow: 0 2px 12px rgba(160, 120, 64, 0.08);
    overflow: hidden;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    box-sizing: border-box;
    transition: box-shadow 0.2s ease;
  }

  .mowmy-feature-banner__card:hover {
    box-shadow: 0 6px 24px rgba(160, 120, 64, 0.15);
  }

  .mowmy-feature-banner__card img {
    width: 100%;
    height: auto;
    object-fit: contain;
    display: block;
  }

  @media (max-width: 768px) {
  .mowmy-feature-banner {
    width: 100%;
    overflow: hidden;
    box-sizing: border-box;
  }
  .mowmy-feature-banner__grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
    width: 100%;
  }
  .mowmy-feature-banner__title {
    font-size: 22px;
  }
  .mowmy-feature-banner__inner {
    padding: 0 16px;
    width: 100%;
    box-sizing: border-box;
  }
  .mowmy-feature-banner__card {
    padding: 12px;
    max-width: 100%;
    overflow: hidden;
  }
  .mowmy-feature-banner__card img {
    max-width: 100%;
  }
}
</style>

{%- liquid
  assign feature_banner_blocks = section.blocks | where: "type", "feature_card"
-%}

{% assign feature_label = section.settings.feature_label | default: "WHY MOWMY TAILS" %}
{% assign feature_heading = section.settings.feature_heading | default: "Thoughtful care for happy pets" %}

<div class="mowmy-feature-banner">
  <div class="mowmy-feature-banner__inner">

    {% if feature_label != blank or feature_heading != blank %}
      <div class="mowmy-feature-banner__heading-wrap">
        {% if feature_label != blank %}
          <span class="mowmy-feature-banner__label">{{ feature_label }}</span>
        {% endif %}
        {% if feature_heading != blank %}
          <h2 class="mowmy-feature-banner__title">{{ feature_heading }}</h2>
        {% endif %}
      </div>
    {% endif %}

    <div class="mowmy-feature-banner__grid">
      {% for block in feature_banner_blocks %}
        <div class="mowmy-feature-banner__card" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 600 | image_tag:
              alt: block.settings.image_alt,
              loading: 'lazy',
              widths: '300, 400, 600'
            }}
          {% else %}
            <div style="width:100%;aspect-ratio:1;background:#F5EFE6;border-radius:12px;display:flex;align-items:center;justify-content:center;color:#A07840;font-size:13px;">
              Add image
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>

  </div>
</div>


  <!-- Brand Promise Grid -->
