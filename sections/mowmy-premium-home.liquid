.mowmy-slider-card__text p {
  color: #6b5a4b !important;
}

.mowmy-shop-now {
  background: #a8792b !important;
  color: #fff9f0 !important;
  border: 3px solid #2b2118 !important;
  box-shadow: 4px 4px 0 #2b2118 !important;
}

.mowmy-slider-card:hover .mowmy-shop-now {
  background: #2b2118 !important;
  color: #fff9f0 !important;
  box-shadow: 3px 3px 0 #a8792b !important;
}

.mowmy-arrow {
  background: #fff9f0 !important;
  color: #2b2118 !important;
  border: 3px solid #a8792b !important;
  box-shadow: 4px 4px 0 #d8c3a3 !important;
}

.mowmy-arrow:hover {
  background: #2b2118 !important;
  color: #fff9f0 !important;
  box-shadow: 3px 3px 0 #a8792b !important;
}

@media (max-width: 640px) {
  .mowmy-tt-head h3 {
    text-shadow: 3px 3px 0 #d8c3a3 !important;
  }
}

/* Fix Shop Now button alignment */
.mowmy-shop-now {
  width: 100% !important;
  min-height: 52px !important;
  padding: 0 18px !important;
  background: #a8792b !important;
  color: #fff9f0 !important;
  border: 3px solid #2b2118 !important;
  border-radius: 8px !important;
  box-shadow: 5px 5px 0 #2b2118 !important;

  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  gap: 10px !important;

  font-size: 13px !important;
  font-weight: 900 !important;
  line-height: 1 !important;
  text-transform: uppercase !important;
  letter-spacing: 0.08em !important;
  text-align: center !important;
}

.mowmy-btn-arrow {
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
  font-size: 16px !important;
  line-height: 1 !important;
  transform: translateY(-1px);
}

.mowmy-slider-card:hover .mowmy-shop-now {
  background: #2b2118 !important;
  color: #fff9f0 !important;
  box-shadow: 3px 3px 0 #a8792b !important;
  transform: translate(2px, 2px);
}

/* Shop by Category heading like Featured Collections */
.mowmy-shop-category__head {
  text-align: center;
  margin-bottom: 38px;
}

.mowmy-shop-category__head p {
  margin: 0 0 10px;
  color: #a8792b;
  text-transform: uppercase;
  letter-spacing: 0.16em;
  font-size: 12px;
  font-weight: 800;
}

.mowmy-shop-category__title {
  margin: 0 !important;
  display: inline-block;
  font-size: clamp(34px, 5vw, 58px) !important;
  line-height: 1 !important;
  font-weight: 900 !important;
  letter-spacing: 0.04em !important;
  text-transform: uppercase !important;
  color: #2b2118 !important;
  text-shadow: 4px 4px 0 #d8c3a3 !important;
  transform: rotate(-2deg);
}

.mowmy-shop-category__head span {
  display: block;
  margin-top: 18px;
  color: #5f5042;
  font-size: 15px;
  font-weight: 700;
}

@media screen and (max-width: 640px) {
  .mowmy-shop-category__head {
    margin-bottom: 28px;
  }

  .mowmy-shop-category__title {
    font-size: 34px !important;
    text-shadow: 3px 3px 0 #d8c3a3 !important;
  }

  .mowmy-shop-category__head span {
    font-size: 13px;
    padding: 0 12px;
  }
}

/* FINAL LOCK - Mobile Newsletter / Community Fix */
@media screen and (max-width: 749px) {
  .mowmy-newsletter-v2 {
    width: calc(100% - 32px) !important;
    margin: 32px auto 52px !important;
    padding: 30px 22px !important;
    display: flex !important;
    flex-direction: column !important;
    gap: 22px !important;
    border-radius: 18px !important;
    overflow: hidden !important;
  }

  .mowmy-newsletter-v2 h3 {
    font-size: 26px !important;
    line-height: 1.22 !important;
    max-width: 100% !important;
  }

  .mowmy-newsletter-v2 form {
    width: 100% !important;
    height: auto !important;
    display: grid !important;
    grid-template-columns: 1fr !important;
    gap: 12px !important;
    background: transparent !important;
    padding: 0 !important;
    overflow: visible !important;
  }

  .mowmy-newsletter-v2 input,
  .mowmy-newsletter-v2 input[type="email"] {
    width: 100% !important;
    max-width: 100% !important;
    min-width: 0 !important;
    height: 54px !important;
    min-height: 54px !important;
    flex: none !important;
    display: block !important;
    background: #fffdfb !important;
    border: 1px solid rgba(216, 195, 163, 0.75) !important;
    border-radius: 10px !important;
    padding: 0 16px !important;
    font-size: 14px !important;
    line-height: 54px !important;
    color: #2b2118 !important;
    box-sizing: border-box !important;
  }

  .mowmy-newsletter-v2 button {
    width: 100% !important;
    max-width: 100% !important;
    height: 54px !important;
    min-height: 54px !important;
    flex: none !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    border-radius: 10px !important;
    padding: 0 16px !important;
    font-size: 12px !important;
    letter-spacing: 0.07em !important;
    white-space: nowrap !important;
    box-sizing: border-box !important;
  }
}

{% endstylesheet %}

