<section><div class="mt-page-hero"><div class="mt-page"><span class="mt-eyebrow">The pet parent journal</span><h1>{{ blog.title }}</h1><p>Practical care, style and everyday wellbeing ideas for happier tails.</p></div></div><div class="mt-page mt-section">{% paginate blog.articles by 9 %}<div class="mt-blog-grid">{% for article in blog.articles %}<article class="mt-article-card mt-reveal"><a href="{{ article.url }}">{% if article.image %}{{ article.image | image_url: width: 900 | image_tag: loading: 'lazy', alt: article.title }}{% else %}{{ 'image' | placeholder_svg_tag: 'mt-placeholder' }}{% endif %}</a><div class="mt-article-card__body"><time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">{{ article.published_at | date: '%B %d, %Y' }}</time><h2><a href="{{ article.url }}">{{ article.title }}</a></h2><p>{{ article.excerpt_or_content | strip_html | truncatewords: 22 }}</p><a class="mt-text-link" href="{{ article.url }}">Read article</a></div></article>{% else %}<div class="mt-empty-state"><h2>Stories are coming soon.</h2></div>{% endfor %}</div>{% if paginate.pages > 1 %}<nav class="mt-pagination">{{ paginate | default_pagination }}</nav>{% endif %}{% endpaginate %}</div></section>
{% schema %}{"name":"Main blog","settings":[]} {% endschema %}
