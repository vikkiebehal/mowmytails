<section class="mt-hero">
  <div class="mt-page mt-hero-grid">
    <div class="mt-hero-copy">
      <span class="mt-kicker">{{ section.settings.kicker }}</span>
      <h1 class="mt-serif">{{ section.settings.heading }}</h1>
      <p>{{ section.settings.subtext }}</p>
      <div class="mt-hero-actions">
        <a class="mt-btn mt-btn--primary" href="{{ section.settings.primary_link | default: '/collections/new-arrivals' }}">{{ section.settings.primary_text }}</a>
        <a class="mt-btn mt-btn--secondary" href="{{ section.settings.secondary_link | default: '/collections/best-sellers' }}">{{ section.settings.secondary_text }}</a>
      </div>
    </div>

    <div class="mt-hero-media" aria-label="{{ section.settings.image_alt | escape }}">
      {% if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 1400 | image_tag: class: 'mt-hero-image', loading: 'eager', alt: section.settings.image_alt }}
      {% else %}
        <img class="mt-hero-image" src="{{ 'mt-photo-hero-lifestyle.jpg' | asset_url }}" alt="{{ section.settings.image_alt }}" loading="eager">
      {% endif %}
      <div class="mt-hero-overlay"></div>
      <div class="mt-hero-badge">
        <strong>{{ section.settings.badge_title }}</strong>
        <span>{{ section.settings.badge_text }}</span>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Mowmy Hero",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Comfort, style & care for everyday routines" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Style Your Pet’s Everyday Comfort" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Premium essentials for walks, naps, playtime & cuddles." },
    { "type": "text", "id": "primary_text", "label": "Primary button", "default": "Shop New Arrivals" },
    { "type": "url", "id": "primary_link", "label": "Primary link" },
    { "type": "text", "id": "secondary_text", "label": "Secondary button", "default": "Explore Best Sellers" },
    { "type": "url", "id": "secondary_link", "label": "Secondary link" },
    { "type": "image_picker", "id": "image", "label": "Hero image" },
    { "type": "text", "id": "image_alt", "label": "Image alt text", "default": "Dog and cat relaxing on a cozy pet bed with premium Mowmy Tails accessories" },
    { "type": "text", "id": "badge_title", "label": "Badge title", "default": "Pet-safe. Comfort-first." },
    { "type": "text", "id": "badge_text", "label": "Badge text", "default": "Designed for Indian homes, walks and weather." }
  ],
  "presets": [{ "name": "Mowmy Hero" }]
}
{% endschema %}
