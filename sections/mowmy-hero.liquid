<section class="mt-reference-hero" data-hero-section>
  <div class="mt-reference-hero__slider" data-hero-slider aria-label="Pet lifestyle gallery">
    {% if section.blocks.size > 0 %}
      {% for block in section.blocks %}
        <div class="mt-reference-hero__slide mt-hero-slide {% if forloop.first %}is-active{% endif %}" data-hero-slide {{ block.shopify_attributes }}>
          {% if block.settings.image %}
            {{ block.settings.image | image_url: width: 2400 | image_tag: loading: 'eager', widths: '750, 1100, 1600, 2000, 2400', sizes: '100vw', alt: block.settings.alt }}
          {% else %}
            {% case forloop.index %}
              {% when 1 %}<img src="{{ 'mt-photo-pet-apparel.jpg' | asset_url }}" width="1200" height="900" alt="Dog wearing premium pet apparel" loading="eager">
              {% when 2 %}<img src="{{ 'mt-photo-hero-lifestyle.jpg' | asset_url }}" width="1672" height="941" alt="Pets relaxing at home" loading="lazy">
              {% else %}<img src="{{ 'mt-photo-dogs.jpg' | asset_url }}" width="1200" height="900" alt="Happy dog in a warm studio setting" loading="lazy">
            {% endcase %}
          {% endif %}
        </div>
      {% endfor %}
    {% else %}
      <div class="mt-reference-hero__slide mt-hero-slide is-active" data-hero-slide><img src="{{ 'mt-photo-pet-apparel.jpg' | asset_url }}" width="1200" height="900" alt="Dog wearing premium pet apparel" loading="eager"></div>
    {% endif %}
  </div>

  <div class="mt-reference-hero__shade" aria-hidden="true"></div>
  <div class="mt-page mt-reference-hero__content">
    <div class="mt-reference-hero__copy mt-reveal">
      <span class="mt-reference-hero__eyebrow">{{ section.settings.eyebrow }}</span>
      <h1>{{ section.settings.heading }}</h1>
      <p>{{ section.settings.subtext }}</p>
      <div class="mt-reference-hero__actions">
        <a class="mt-reference-button mt-reference-button--gold" href="{{ section.settings.primary_link | default: routes.all_products_collection_url }}">{{ section.settings.primary_label }}</a>
        <a class="mt-reference-button mt-reference-button--ghost" href="{{ section.settings.secondary_link | default: routes.collections_url }}">{{ section.settings.secondary_label }}</a>
      </div>
      <div class="mt-reference-hero__giving">
        <strong>{{ section.settings.love_heading }}</strong>
        <span>{{ section.settings.love_text }}</span>
      </div>
    </div>

    <div class="mt-reference-hero__stats" aria-label="Mowmy Tails highlights">
      <div><strong>{{ section.settings.stat_1_value }}</strong><span>{{ section.settings.stat_1_label }}</span></div>
      <div><strong>{{ section.settings.stat_2_value }}</strong><span>{{ section.settings.stat_2_label }}</span></div>
      <div><strong>{{ section.settings.stat_3_value }}</strong><span>{{ section.settings.stat_3_label }}</span></div>
    </div>
  </div>

  <img class="mt-reference-hero__badge" src="{{ 'made-in-india-badge.svg' | asset_url }}" width="240" height="240" alt="Proudly Made in India for Indian Pets">

  {% if section.blocks.size > 1 %}
    <div class="mt-reference-hero__dots" aria-label="Hero slider controls">
      {% for block in section.blocks %}<button class="mt-slider-dot {% if forloop.first %}is-active{% endif %}" type="button" data-slide-dot aria-label="Show slide {{ forloop.index }}"></button>{% endfor %}
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Premium Hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "For pets who dress better than us" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Clothes for every pet." },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Everyday comfort, considered details and playful style for the pets who make a house feel like home." },
    { "type": "text", "id": "love_heading", "label": "Highlight message", "default": "1 Purchase = 1 Bowl of Love" },
    { "type": "text", "id": "love_text", "label": "Supporting line", "default": "Every order helps us care for a pet in need." },
    { "type": "text", "id": "primary_label", "label": "Primary button", "default": "Shop the collection" },
    { "type": "url", "id": "primary_link", "label": "Primary link" },
    { "type": "text", "id": "secondary_label", "label": "Secondary button", "default": "Our story" },
    { "type": "url", "id": "secondary_link", "label": "Secondary link" },
    { "type": "text", "id": "stat_1_value", "label": "Statistic 1 value", "default": "15k+" },
    { "type": "text", "id": "stat_1_label", "label": "Statistic 1 label", "default": "Happy pets" },
    { "type": "text", "id": "stat_2_value", "label": "Statistic 2 value", "default": "1.8k+" },
    { "type": "text", "id": "stat_2_label", "label": "Statistic 2 label", "default": "Five-star reviews" },
    { "type": "text", "id": "stat_3_value", "label": "Statistic 3 value", "default": "800+" },
    { "type": "text", "id": "stat_3_label", "label": "Statistic 3 label", "default": "Bowls donated" }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Lifestyle slide",
      "limit": 5,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "alt", "label": "Alt text", "default": "Premium pet lifestyle" }
      ]
    }
  ],
  "presets": [{ "name": "Premium Hero", "blocks": [{ "type": "slide" }, { "type": "slide" }, { "type": "slide" }] }]
}
{% endschema %}
