<section class="mt-hero">
  <div class="mt-page mt-hero-grid">
    <div class="mt-hero-copy">
      <span class="mt-eyebrow">{{ section.settings.eyebrow }}</span>
      <h1>{{ section.settings.heading }}</h1>
      <p>{{ section.settings.subtext }}</p>
      <div class="mt-love-message"><strong>{{ section.settings.love_heading }}</strong><small>{{ section.settings.love_text }}</small></div>
      <div class="mt-hero-actions"><a class="mt-btn mt-btn--primary" href="{{ section.settings.primary_link | default: routes.all_products_collection_url }}">{{ section.settings.primary_label }}</a><a class="mt-btn mt-btn--secondary" href="{{ section.settings.secondary_link | default: routes.collections_url }}">{{ section.settings.secondary_label }}</a></div>
      <div class="mt-trust-pills"><span>Soft Fabrics</span><span>Pet-Safe Products</span><span>Easy Returns</span></div>
    </div>
    <div class="mt-hero-slider" data-hero-slider>
      {% for block in section.blocks %}<div class="mt-hero-slide {% if forloop.first %}is-active{% endif %}" data-hero-slide {{ block.shopify_attributes }}>{% if block.settings.image %}{{ block.settings.image | image_url: width: 1400 | image_tag: loading: 'eager', alt: block.settings.alt }}{% else %}{{ 'lifestyle-1' | placeholder_svg_tag: 'mt-placeholder' }}{% endif %}</div>{% endfor %}
      <div class="mt-floating-note"><strong>{{ section.settings.slider_note }}</strong><span>{{ section.settings.slider_subnote }}</span></div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Premium Hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Designed for their happiest days" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Premium Pet Essentials for Happy Tails" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Stylish apparel, comfy beds, playful toys, and everyday accessories made for dogs and cats." },
    { "type": "text", "id": "love_heading", "label": "Highlight message", "default": "1 Purchase = 1 Bowl of Love" },
    { "type": "text", "id": "love_text", "label": "Supporting line", "default": "Every order helps us spread a little more love and care for pets." },
    { "type": "text", "id": "primary_label", "label": "Primary button", "default": "Shop New Arrivals" },
    { "type": "url", "id": "primary_link", "label": "Primary link" },
    { "type": "text", "id": "secondary_label", "label": "Secondary button", "default": "Explore Collections" },
    { "type": "url", "id": "secondary_link", "label": "Secondary link" },
    { "type": "text", "id": "slider_note", "label": "Slider note", "default": "Comfort looks good on them" },
    { "type": "text", "id": "slider_subnote", "label": "Slider supporting note", "default": "Made for walks, naps and everything between" }
  ],
  "blocks": [{ "type": "slide", "name": "Lifestyle slide", "settings": [{ "type": "image_picker", "id": "image", "label": "Image" }, { "type": "text", "id": "alt", "label": "Alt text", "default": "Premium pet lifestyle" }] }],
  "presets": [{ "name": "Premium Hero", "blocks": [{ "type": "slide" }, { "type": "slide" }, { "type": "slide" }] }]
}
{% endschema %}