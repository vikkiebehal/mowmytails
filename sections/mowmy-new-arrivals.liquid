{% render 'home-product-collection', section: section %}

{% schema %}
{
  "name": "New Arrivals",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Freshly fetched" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "New Arrivals" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "New comfort, color and joy for their everyday routine." },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "checkbox", "id": "show_dynamic_products", "label": "Use Shopify collection products instead of pet demo cards", "default": false },
    { "type": "range", "id": "limit", "label": "Products", "min": 4, "max": 12, "step": 1, "default": 4 },
    { "type": "checkbox", "id": "soft_background", "label": "Soft background", "default": true }
  ],
  "presets": [{ "name": "New Arrivals" }]
}
{% endschema %}
