{% render 'home-product-collection', section: section %}

{% schema %}
{
  "name": "Best Sellers",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Pet parent favorites" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Best Sellers" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "The pieces pets love and their humans recommend." },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "limit", "label": "Products", "min": 4, "max": 12, "step": 1, "default": 4 },
    { "type": "checkbox", "id": "soft_background", "label": "Soft background", "default": false }
  ],
  "presets": [{ "name": "Best Sellers" }]
}
{% endschema %}