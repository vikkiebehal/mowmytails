<section>
  <div class="mt-page-hero"><div class="mt-page"><div class="mt-breadcrumbs"><a href="{{ routes.root_url }}">Home</a><span>/</span><a href="{{ routes.collections_url }}">Collections</a><span>/</span><span>{{ collection.title }}</span></div><span class="mt-eyebrow">Curated for happy tails</span><h1>{{ collection.title }}</h1>{% if collection.description != blank %}<div>{{ collection.description }}</div>{% endif %}</div></div>
  <div class="mt-page mt-section">
    <div class="mt-collection-toolbar"><span>{{ collection.products_count }} products</span><form method="get"><label for="SortBy">Sort by </label><select id="SortBy" name="sort_by" data-auto-submit>{% assign sort_by = collection.sort_by | default: collection.default_sort_by %}{% for option in collection.sort_options %}<option value="{{ option.value }}" {% if option.value == sort_by %}selected{% endif %}>{{ option.name }}</option>{% endfor %}</select></form></div>
    {% paginate collection.products by section.settings.products_per_page %}
      <div class="mt-collection-layout">
        <aside class="mt-filters-desktop" aria-label="Product filters"><form method="get">{% for filter in collection.filters %}<details class="mt-filter-group" open><summary>{{ filter.label }}</summary><div class="mt-filter-list">{% case filter.type %}{% when 'boolean','list' %}{% for value in filter.values %}<label><input type="checkbox" name="{{ value.param_name }}" value="{{ value.value }}" {% if value.active %}checked{% endif %} {% if value.count == 0 and value.active == false %}disabled{% endif %} data-auto-submit><span>{{ value.label }} ({{ value.count }})</span></label>{% endfor %}{% when 'price_range' %}<label>From <input type="number" name="{{ filter.min_value.param_name }}" value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}" min="0" placeholder="0"></label><label>To <input type="number" name="{{ filter.max_value.param_name }}" value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}" min="0" placeholder="{{ filter.range_max | money_without_currency | replace: ',', '' }}"></label><button class="mt-btn mt-btn--small mt-btn--secondary" type="submit">Apply</button>{% endcase %}</div></details>{% endfor %}{% if collection.filters.size > 0 %}<a class="mt-text-link" href="{{ collection.url }}">Clear all</a>{% endif %}</form></aside>
        <div>{% if collection.products_count > 0 %}<div class="mt-product-grid">{% for product in collection.products %}{% render 'product-card', product: product, show_rating: true %}{% endfor %}</div>{% else %}<div class="mt-empty-state"><span class="mt-empty-state__mark">M</span><h2>No products match those filters.</h2><p>Clear the filters and discover the full collection.</p><a class="mt-btn mt-btn--primary" href="{{ collection.url }}">Clear filters</a></div>{% endif %}{% if paginate.pages > 1 %}<nav class="mt-pagination" aria-label="Pagination">{{ paginate | default_pagination }}</nav>{% endif %}</div>
      </div>
    {% endpaginate %}
  </div>
</section>
{% schema %}{"name":"Collection product grid","settings":[{"type":"range","id":"products_per_page","label":"Products per page","min":8,"max":32,"step":4,"default":16}]}{% endschema %}
