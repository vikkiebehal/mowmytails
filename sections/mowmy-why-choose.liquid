<section class="mt-section mt-section--soft mt-reveal mt-why-choose">
  <div class="mt-page">
    <div class="mt-section-head">
      <span class="mt-eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="mt-title">{{ section.settings.heading }}</h2>
      <p class="mt-subtitle">{{ section.settings.subtext }}</p>
    </div>
    <div class="mt-trust-grid">
      {% for block in section.blocks %}
        <div class="mt-trust-item" {{ block.shopify_attributes }}>
          <div class="mt-trust-icon">
            {% if block.settings.show_made_in_india_badge %}
              <img src="{{ 'made-in-india-badge.svg' | asset_url }}" width="240" height="240" alt="Proudly Made in India for Indian Pets">
            {% else %}
              {{ block.settings.icon }}
            {% endif %}
          </div>
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.text }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Why Choose Mowmy Tails",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Why choose us" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Thoughtful Essentials for Everyday Care" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Comfort, safety and detail-led quality for pets who are family." }
  ],
  "blocks": [
    { "type": "benefit", "name": "Benefit", "settings": [
      { "type": "text", "id": "icon", "label": "Number/Icon", "default": "01" },
      { "type": "checkbox", "id": "show_made_in_india_badge", "label": "Show Made in India badge", "default": false },
      { "type": "text", "id": "title", "label": "Title", "default": "Pet-Safe Materials" },
      { "type": "textarea", "id": "text", "label": "Text", "default": "Thoughtful materials chosen for everyday life." }
    ] }
  ],
  "presets": [{ "name": "Why Choose Mowmy Tails", "blocks": [
    { "type": "benefit", "settings": { "icon": "01", "title": "Pet-Safe Materials" } },
    { "type": "benefit", "settings": { "icon": "02", "title": "Comfortable Fit" } },
    { "type": "benefit", "settings": { "icon": "03", "title": "Curated Quality" } },
    { "type": "benefit", "settings": { "icon": "04", "title": "Fast Delivery" } },
    { "type": "benefit", "settings": { "icon": "05", "show_made_in_india_badge": true, "title": "Made in India", "text": "Proudly made in India for Indian pets." } }
  ] }]
}
{% endschema %}
