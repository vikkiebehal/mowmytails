<section class="mt-section mt-reveal">
  <div class="mt-page">
    <div class="mt-section-head">
      <span class="mt-eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="mt-title mt-serif">{{ section.settings.heading }}</h2>
      {% if section.settings.subtext != blank %}<p class="mt-subtitle">{{ section.settings.subtext }}</p>{% endif %}
    </div>

    <div class="mt-category-grid">
      {% for block in section.blocks %}
        <a class="mt-category-card" href="{{ block.settings.link }}" aria-label="Shop {{ block.settings.title }}" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 700 | image_tag: class: 'mt-category-image', loading: 'lazy', alt: block.settings.alt }}
          {% else %}
            {% case forloop.index %}
              {% when 1 %}<img class="mt-category-image" src="{{ 'mt-photo-walk-essentials.jpg' | asset_url }}" width="1200" height="900" alt="{{ block.settings.alt }}" loading="lazy">
              {% when 2 %}<img class="mt-category-image" src="{{ 'mt-photo-pet-apparel.jpg' | asset_url }}" width="1200" height="900" alt="{{ block.settings.alt }}" loading="lazy">
              {% when 3 %}<img class="mt-category-image" src="{{ 'mt-photo-cozy-beds.jpg' | asset_url }}" width="1200" height="900" alt="{{ block.settings.alt }}" loading="lazy">
              {% when 4 %}<img class="mt-category-image" src="{{ 'mt-photo-toys-play.jpg' | asset_url }}" width="1200" height="900" alt="{{ block.settings.alt }}" loading="lazy">
              {% when 5 %}<img class="mt-category-image" src="{{ 'mt-photo-bowls-feeders.jpg' | asset_url }}" width="1200" height="900" alt="{{ block.settings.alt }}" loading="lazy">
              {% else %}<img class="mt-category-image" src="{{ 'mt-photo-grooming-picks.jpg' | asset_url }}" width="1200" height="900" alt="{{ block.settings.alt }}" loading="lazy">
            {% endcase %}
          {% endif %}
          <div class="mt-category-content">
            <h3 class="mt-serif">{{ block.settings.title }}</h3>
            <span>{{ block.settings.cta }}</span>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Shop by Category",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop by category" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Essentials for every little routine" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category card",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Walk Essentials" },
        { "type": "text", "id": "cta", "label": "CTA text", "default": "Shop collection" },
        { "type": "url", "id": "link", "label": "Link", "default": "/collections/all" },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "alt", "label": "Alt text", "default": "Mowmy Tails real-life pet lifestyle category photo" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by Category",
      "blocks": [
        { "type": "category", "settings": { "title": "Walk Essentials", "link": "/collections/walk-essentials", "alt": "Golden retriever wearing a green walking harness outdoors" } },
        { "type": "category", "settings": { "title": "Pet Apparel", "link": "/collections/pet-apparel", "alt": "Small dog wearing a premium green sweater at home" } },
        { "type": "category", "settings": { "title": "Cozy Beds", "link": "/collections/cozy-beds", "alt": "Golden retriever sleeping on a soft cozy pet bed" } },
        { "type": "category", "settings": { "title": "Toys & Play", "link": "/collections/toys-play", "alt": "Puppy playing with a soft plush toy" } },
        { "type": "category", "settings": { "title": "Bowls & Feeders", "link": "/collections/bowls-feeders", "alt": "Golden retriever eating from premium green pet bowls" } },
        { "type": "category", "settings": { "title": "Grooming Picks", "link": "/collections/grooming-picks", "alt": "Golden retriever being gently groomed at home" } }
      ]
    }
  ]
}
{% endschema %}
