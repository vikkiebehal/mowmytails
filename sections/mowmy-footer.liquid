<footer class="mt-footer">
  <div class="mt-page">
    <div class="mt-footer-grid">
      <div class="mt-footer-brand"><a class="mt-brand" href="{{ routes.root_url }}"><span class="mt-brand-mark">M</span><span class="mt-brand-text"><strong>{{ section.settings.brand_name }}</strong><span>{{ section.settings.tagline }}</span></span></a><p>{{ section.settings.description }}</p><div class="mt-social-links"><a href="{{ section.settings.instagram }}" aria-label="Instagram">ig</a><a href="{{ section.settings.facebook }}" aria-label="Facebook">f</a><a href="{{ section.settings.pinterest }}" aria-label="Pinterest">p</a></div></div>
      <div class="mt-footer-column"><h3>Shop</h3><nav class="mt-footer-links">{% for link in section.settings.shop_menu.links %}<a href="{{ link.url }}">{{ link.title }}</a>{% else %}<a href="{{ routes.collections_url }}/dogs">Dogs</a><a href="{{ routes.collections_url }}/cats">Cats</a><a href="{{ routes.collections_url }}/pet-apparel">Apparel</a><a href="{{ routes.collections_url }}/beds">Beds</a><a href="{{ routes.collections_url }}/toys">Toys</a>{% endfor %}</nav></div>
      <div class="mt-footer-column"><h3>Help</h3><nav class="mt-footer-links">{% for link in section.settings.help_menu.links %}<a href="{{ link.url }}">{{ link.title }}</a>{% else %}<a href="/pages/contact">Contact us</a><a href="/pages/faq">FAQs</a><a href="/pages/size-guide">Size guide</a><a href="/policies/shipping-policy">Shipping</a><a href="/policies/refund-policy">Returns</a>{% endfor %}</nav></div>
      <div class="mt-footer-column"><h3>Contact</h3><div class="mt-footer-links"><span>{{ section.settings.email }}</span><span>{{ section.settings.phone }}</span><span>{{ section.settings.address }}</span></div></div>
    </div>
    <div class="mt-footer-bottom"><span>© {{ 'now' | date: '%Y' }} {{ shop.name }}. Made with care for happy tails.</span><div class="mt-payment-row"><span>Secure</span><span>Visa</span><span>UPI</span><span>COD</span></div></div>
  </div>
</footer>
{% schema %}{"name":"Premium footer","settings":[{"type":"text","id":"brand_name","label":"Brand name","default":"Mowmy Tails"},{"type":"text","id":"tagline","label":"Tagline","default":"Premium pet lifestyle"},{"type":"textarea","id":"description","label":"Description","default":"Thoughtfully chosen apparel, beds, toys and everyday essentials for pets who are family."},{"type":"link_list","id":"shop_menu","label":"Shop menu"},{"type":"link_list","id":"help_menu","label":"Help menu"},{"type":"text","id":"email","label":"Email","default":"hello@mowmytails.com"},{"type":"text","id":"phone","label":"Phone","default":"+91 00000 00000"},{"type":"textarea","id":"address","label":"Address","default":"India"},{"type":"url","id":"instagram","label":"Instagram"},{"type":"url","id":"facebook","label":"Facebook"},{"type":"url","id":"pinterest","label":"Pinterest"}]}{% endschema %}
