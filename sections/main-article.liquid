<article class="mt-article"><div class="mt-breadcrumbs"><a href="{{ routes.root_url }}">Home</a><span>/</span><a href="{{ blog.url }}">{{ blog.title }}</a></div><span class="mt-eyebrow">Pet parent journal</span><h1 class="mt-title">{{ article.title }}</h1><time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">{{ article.published_at | date: '%B %d, %Y' }}</time>{% if article.image %}{{ article.image | image_url: width: 1500 | image_tag: class: 'mt-article__image', loading: 'eager', alt: article.title }}{% endif %}<div class="mt-rte">{{ article.content }}</div><a class="mt-btn mt-btn--secondary" href="{{ blog.url }}">Back to journal</a></article>
{% schema %}{"name":"Main article","settings":[]} {% endschema %}
