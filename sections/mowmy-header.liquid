<header class="mt-site-header">
  <div class="mt-page mt-header-inner">
    <a class="mt-brand" href="{{ routes.root_url }}" aria-label="{{ shop.name }} home">
      <span class="mt-brand-mark">{{ section.settings.brand_initial }}</span>
      <span class="mt-brand-text"><strong>{{ section.settings.brand_name }}</strong><span>{{ section.settings.tagline }}</span></span>
    </a>
    <nav class="mt-nav" aria-label="Primary navigation">
      {% for link in section.settings.menu.links %}<a href="{{ link.url }}">{{ link.title }}</a>{% else %}<a href="{{ routes.root_url }}">Home</a><a href="{{ routes.all_products_collection_url }}">Shop All</a><a href="{{ routes.collections_url }}/dogs">Dogs</a><a href="{{ routes.collections_url }}/cats">Cats</a><a href="{{ routes.collections_url }}/pet-apparel">Apparel</a><a href="{{ routes.collections_url }}/accessories">Accessories</a><a href="{{ routes.collections_url }}/beds">Beds</a><a href="{{ routes.collections_url }}/toys">Toys</a><a href="{{ routes.root_url }}pages/about">About</a><a href="{{ routes.root_url }}pages/contact">Contact</a>{% endfor %}
    </nav>
    <div class="mt-header-actions">
      <button class="mt-header-icon" type="button" aria-label="Search" data-drawer-open="SearchDrawer"><svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/><path d="m16.5 16.5 4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg></button>
      {% if shop.customer_accounts_enabled %}<a class="mt-header-icon mt-account-link" href="{{ routes.account_url }}" aria-label="Account"><svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="2"/><path d="M4.5 21c1.5-4.3 4-6.4 7.5-6.4s6 2.1 7.5 6.4" stroke="currentColor" stroke-width="2"/></svg></a>{% endif %}
      <button class="mt-header-icon" type="button" aria-label="Open shopping bag" data-drawer-open="CartDrawer"><svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M6 8h12l-1 13H7L6 8Z" stroke="currentColor" stroke-width="2"/><path d="M9 8a3 3 0 0 1 6 0" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg><span class="mt-cart-count" data-cart-count {% if cart.item_count == 0 %}hidden{% endif %}>{{ cart.item_count }}</span></button>
      <button class="mt-header-icon mt-menu-button" type="button" aria-label="Open menu" data-drawer-open="MobileMenu"><svg aria-hidden="true" width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg></button>
    </div>
  </div>
</header>
<div class="mt-drawer mt-mobile-menu" id="MobileMenu" hidden>
  <button class="mt-drawer__scrim" type="button" aria-label="Close menu" data-drawer-close></button>
  <aside class="mt-mobile-menu__panel" aria-label="Mobile navigation">
    <div class="mt-mobile-menu__header"><a class="mt-brand" href="{{ routes.root_url }}"><span class="mt-brand-mark">{{ section.settings.brand_initial }}</span><span class="mt-brand-text"><strong>{{ section.settings.brand_name }}</strong></span></a><button class="mt-icon-button" type="button" aria-label="Close menu" data-drawer-close>×</button></div>
    <nav class="mt-mobile-nav">{% for link in section.settings.menu.links %}<a href="{{ link.url }}">{{ link.title }}</a>{% else %}<a href="{{ routes.root_url }}">Home</a><a href="{{ routes.all_products_collection_url }}">Shop All</a><a href="{{ routes.collections_url }}/dogs">Dogs</a><a href="{{ routes.collections_url }}/cats">Cats</a><a href="{{ routes.collections_url }}/pet-apparel">Apparel</a><a href="{{ routes.collections_url }}/accessories">Accessories</a><a href="{{ routes.collections_url }}/beds">Beds</a><a href="{{ routes.collections_url }}/toys">Toys</a><a href="{{ routes.root_url }}pages/about">About</a><a href="{{ routes.root_url }}pages/contact">Contact</a>{% endfor %}</nav>
    <div class="mt-mobile-nav__footer"><a href="{{ routes.search_url }}">Search the store</a>{% if shop.customer_accounts_enabled %}<a href="{{ routes.account_url }}">My account</a>{% endif %}</div>
  </aside>
</div>
{% schema %}{"name":"Premium header","settings":[{"type":"text","id":"brand_initial","label":"Brand initial","default":"M"},{"type":"text","id":"brand_name","label":"Brand name","default":"Mowmy Tails"},{"type":"text","id":"tagline","label":"Tagline","default":"Premium pet lifestyle"},{"type":"link_list","id":"menu","label":"Main menu","default":"main-menu"}]}{% endschema %}
