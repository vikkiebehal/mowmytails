<section class="mt-section mt-reveal"><div class="mt-page"><div class="mt-section-head mt-section-head--split"><div><span class="mt-eyebrow">{{ section.settings.eyebrow }}</span><h2 class="mt-title">{{ section.settings.heading }}</h2></div><a class="mt-btn mt-btn--secondary" href="{{ section.settings.link }}">{{ section.settings.label }}</a></div><div class="mt-community-grid">{% for block in section.blocks %}<a href="{{ section.settings.link }}" aria-label="View Mowmy Tails community">{% if block.settings.image %}{{ block.settings.image | image_url: width: 700 | image_tag: loading: 'lazy', alt: block.settings.alt }}{% else %}{% case forloop.index %}{% when 1 %}<img src="{{ 'mt-photo-dogs.jpg' | asset_url }}" width="1200" height="900" alt="Happy dog from the Mowmy Tails community" loading="lazy">{% when 2 %}<img src="{{ 'mt-photo-cats.jpg' | asset_url }}" width="1200" height="900" alt="Cat wearing a premium accessory" loading="lazy">{% when 3 %}<img src="{{ 'mt-photo-story-family.jpg' | asset_url }}" width="1200" height="900" alt="Pet parent sharing a loving moment" loading="lazy">{% else %}<img src="{{ 'mt-photo-pet-apparel.jpg' | asset_url }}" width="1200" height="900" alt="Dog wearing premium pet apparel" loading="lazy">{% endcase %}{% endif %}</a>{% endfor %}</div></div></section>
{% schema %}{"name":"Community gallery","settings":[{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Our community"},{"type":"text","id":"heading","label":"Heading","default":"Loved by Pet Parents"},{"type":"text","id":"label","label":"Button label","default":"Follow Mowmy Tails"},{"type":"url","id":"link","label":"Social link"}],"blocks":[{"type":"image","name":"Community image","limit":8,"settings":[{"type":"image_picker","id":"image","label":"Image"},{"type":"text","id":"alt","label":"Alt text","default":"Mowmy Tails pet community"}]}],"presets":[{"name":"Community gallery","blocks":[{"type":"image"},{"type":"image"},{"type":"image"},{"type":"image"}]}]}{% endschema %}
