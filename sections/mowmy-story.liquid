<section class="mt-section mt-reveal">
  <div class="mt-page">
    <div class="mt-story">
      <div class="mt-story-media">
        {% if section.settings.image != blank %}
          {{ section.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', alt: section.settings.image_alt }}
        {% else %}
          <img src="{{ 'mt-photo-story-family.jpg' | asset_url }}" alt="{{ section.settings.image_alt }}" loading="lazy">
        {% endif %}
      </div>
      <div class="mt-story-copy">
        <span class="mt-eyebrow">{{ section.settings.eyebrow }}</span>
        <h2 class="mt-title mt-serif">{{ section.settings.heading }}</h2>
        <p>{{ section.settings.body }}</p>
        <a class="mt-btn mt-btn--primary" href="{{ section.settings.link | default: '/pages/about-us' }}">{{ section.settings.button_text }}</a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Our Story",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our story" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Made for pets who are family." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "From morning walks to cozy nap corners, Mowmy Tails brings comfort, style and care into every little routine." },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "Our Story" },
    { "type": "url", "id": "link", "label": "Link" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "image_alt", "label": "Image alt text", "default": "Pet parent with dog at home" }
  ],
  "presets": [{ "name": "Our Story" }]
}
{% endschema %}
