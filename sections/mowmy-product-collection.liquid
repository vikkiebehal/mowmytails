<section class="mt-section {% if section.settings.soft_background %}mt-section--soft{% endif %}"><div class="mt-page"><div class="mt-section-head mt-section-head--split"><div><span class="mt-eyebrow">{{ section.settings.eyebrow }}</span><h2 class="mt-title">{{ section.settings.heading }}</h2><p class="mt-subtitle">{{ section.settings.text }}</p></div>{% if section.settings.collection %}<a class="mt-btn mt-btn--secondary" href="{{ section.settings.collection.url }}">View all</a>{% endif %}</div><div class="mt-product-grid">{% for product in section.settings.collection.products limit: section.settings.limit %}{% render 'product-card', product: product, show_rating: true %}{% else %}{% for i in (1..4) %}<article class="mt-product-card"><div class="mt-product-card__media">{{ 'product-' | append: i | placeholder_svg_tag: 'mt-placeholder' }}</div><div class="mt-product-card__body"><span class="mt-stars">★★★★★</span><strong>Premium pet essential</strong><div class="mt-price-row"><strong>{{ 129900 | money }}</strong></div><a class="mt-btn mt-btn--small mt-btn--primary mt-btn--full" href="{{ routes.all_products_collection_url }}">Shop now</a></div></article>{% endfor %}{% endfor %}</div></div></section>
{% schema %}{"name":"Product collection","settings":[{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Pet parent favorites"},{"type":"text","id":"heading","label":"Heading","default":"Best Sellers"},{"type":"textarea","id":"text","label":"Text","default":"Comfort-first essentials chosen again and again."},{"type":"collection","id":"collection","label":"Collection"},{"type":"range","id":"limit","label":"Products","min":4,"max":12,"step":1,"default":4},{"type":"checkbox","id":"soft_background","label":"Soft background","default":false}],"presets":[{"name":"Product collection"}]}{% endschema %}
