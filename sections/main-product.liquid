<section class="mt-product"><div class="mt-page">
  <div class="mt-breadcrumbs" style="justify-content:flex-start"><a href="{{ routes.root_url }}">Home</a><span>/</span>{% if product.collections.first %}<a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a><span>/</span>{% endif %}<span>{{ product.title }}</span></div>
  <div class="mt-product-layout">
    <div class="mt-product-gallery" data-product-gallery><div class="mt-product-thumbs">{% for media in product.media %}<button class="mt-product-thumb {% if forloop.first %}is-active{% endif %}" type="button" data-gallery-thumb="{{ media.id }}" aria-label="View image {{ forloop.index }}">{{ media.preview_image | image_url: width: 180 | image_tag: loading: 'lazy', alt: media.alt | default: product.title }}</button>{% endfor %}</div><div>{% for media in product.media %}<div class="mt-product-main" data-gallery-image="{{ media.id }}" {% unless forloop.first %}hidden{% endunless %}>{{ media.preview_image | image_url: width: 1400 | image_tag: loading: 'eager', widths: '600, 900, 1200, 1400', sizes: '(min-width: 760px) 52vw, 100vw', alt: media.alt | default: product.title }}</div>{% else %}<div class="mt-product-main">{{ 'product-1' | placeholder_svg_tag: 'mt-placeholder' }}</div>{% endfor %}</div></div>
    <div class="mt-product-info"><span class="mt-stars" aria-label="Five out of five stars">★★★★★ <small>Trusted by pet parents</small></span><h1>{{ product.title }}</h1><div class="mt-product-price"><strong>{{ product.selected_or_first_available_variant.price | money }}</strong>{% if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}<s>{{ product.selected_or_first_available_variant.compare_at_price | money }}</s>{% endif %}</div>{% if product.description != blank %}<div class="mt-product-description">{{ product.description | strip_html | truncatewords: 32 }}</div>{% endif %}
      {% form 'product', product, data-ajax-cart-form: '' %}
        {% unless product.has_only_default_variant %}<div class="mt-option"><label for="VariantSelect-{{ section.id }}"><strong>Choose options</strong></label><select id="VariantSelect-{{ section.id }}" name="id">{% for variant in product.variants %}<option value="{{ variant.id }}" {% if variant == product.selected_or_first_available_variant %}selected{% endif %} {% unless variant.available %}disabled{% endunless %}>{{ variant.title }}{% unless variant.available %} · Sold out{% endunless %}</option>{% endfor %}</select></div>{% else %}<input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">{% endunless %}
        <div class="mt-product-actions"><div class="mt-quantity"><button type="button" aria-label="Decrease quantity" data-quantity-change="-1">−</button><input type="number" name="quantity" value="1" min="1" aria-label="Quantity"><button type="button" aria-label="Increase quantity" data-quantity-change="1">+</button></div><button class="mt-btn mt-btn--primary" type="submit" {% unless product.available %}disabled{% endunless %}>{% if product.available %}Add to bag{% else %}Sold out{% endif %}</button></div>
        {% if section.settings.show_dynamic_checkout %}<div class="mt-dynamic-checkout">{{ form | payment_button }}</div>{% endif %}
      {% endform %}
      <div class="mt-product-trust"><span>Pet-safe materials</span><span>Easy returns</span><span>Secure checkout</span></div>
      <div class="mt-accordion"><details open><summary>Description</summary><div class="mt-accordion__content">{{ product.description }}</div></details><details><summary>Shipping & returns</summary><div class="mt-accordion__content">{{ section.settings.shipping_text }}</div></details><details><summary>Size guide</summary><div class="mt-accordion__content">{{ section.settings.size_text }}</div></details><details><summary>Care instructions</summary><div class="mt-accordion__content">{{ section.settings.care_text }}</div></details></div>
    </div>
  </div>
</div></section>
<div class="mt-sticky-atc"><button class="mt-btn mt-btn--primary mt-btn--full" type="button" onclick="document.querySelector('.mt-product-info form [type=submit]').click()">Add to bag · {{ product.selected_or_first_available_variant.price | money }}</button></div>
{% schema %}{"name":"Main product","settings":[{"type":"checkbox","id":"show_dynamic_checkout","label":"Show buy now button","default":true},{"type":"textarea","id":"shipping_text","label":"Shipping and returns","default":"Orders are carefully packed and dispatched quickly. Easy returns are available on eligible unused items."},{"type":"textarea","id":"size_text","label":"Size guide","default":"Measure the neck, widest part of the chest, and back length. Choose the larger size when between sizes."},{"type":"textarea","id":"care_text","label":"Care instructions","default":"Follow the care label. Hand wash or use a gentle cold cycle when suitable, then air dry."}]}{% endschema %}
