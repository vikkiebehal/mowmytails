{% liquid
  assign featured_collection = collections[section.settings.collection]
%}
<section class="mt-section mt-reveal">
  <div class="mt-page">
    <div class="mt-section-head mt-section-head--split">
      <div>
        <span class="mt-eyebrow">{{ section.settings.eyebrow }}</span>
        <h2 class="mt-title mt-serif">{{ section.settings.heading }}</h2>
        <p class="mt-subtitle">{{ section.settings.subtext }}</p>
      </div>
      <a class="mt-btn mt-btn--secondary mt-btn--small" href="{{ section.settings.view_all_link | default: '/collections/best-sellers' }}">{{ section.settings.view_all_text }}</a>
    </div>

    <div class="mt-product-grid">
      {% if featured_collection != blank and featured_collection.products_count > 0 %}
        {% for product in featured_collection.products limit: section.settings.products_to_show %}
          <article class="mt-product-card">
            {% if forloop.index == 1 %}<span class="mt-badge">Best Seller</span>{% elsif forloop.index == 2 %}<span class="mt-badge">New</span>{% elsif forloop.index == 3 %}<span class="mt-badge">Daily Walks</span>{% endif %}
            <a class="mt-product-media" href="{{ product.url }}" aria-label="{{ product.title | escape }}">
              {% if product.featured_image %}
                {{ product.featured_image | image_url: width: 640 | image_tag: loading: 'lazy', alt: product.title }}
              {% endif %}
            </a>
            <div class="mt-product-info">
              <a class="mt-product-title" href="{{ product.url }}">{{ product.title }}</a>
              <div class="mt-product-meta">
                <span class="mt-price">{{ product.price | money }}</span>
                <span class="mt-rating" aria-label="Rated five stars">★★★★★</span>
              </div>
              <a class="mt-quick-add" href="{{ product.url }}">View Product</a>
            </div>
          </article>
        {% endfor %}
      {% else %}
        {% assign demo_titles = "Adventure Comfort Harness|Soft Knit Pet Tee|Cloud Nap Bed|Natural Play Rope" | split: "|" %}
        {% assign demo_prices = "₹1,299|₹799|₹1,899|₹399" | split: "|" %}
        {% assign demo_badges = "Best Seller|New|Cozy Pick|Daily Play" | split: "|" %}
        {% assign demo_images = "mt-photo-walk-essentials.jpg|mt-photo-pet-apparel.jpg|mt-photo-cozy-beds.jpg|mt-photo-toys-play.jpg" | split: "|" %}
        {% for title in demo_titles %}
          <article class="mt-product-card">
            <span class="mt-badge">{{ demo_badges[forloop.index0] }}</span>
            <a class="mt-product-media" href="/collections/all" aria-label="{{ title }}">
              <img class="mt-product-demo-image" src="{{ demo_images[forloop.index0] | asset_url }}" alt="{{ title }} real-life lifestyle product photo" loading="lazy">
            </a>
            <div class="mt-product-info">
              <a class="mt-product-title" href="/collections/all">{{ title }}</a>
              <div class="mt-product-meta">
                <span class="mt-price">{{ demo_prices[forloop.index0] }}</span>
                <span class="mt-rating" aria-label="Rated five stars">★★★★★</span>
              </div>
              <a class="mt-quick-add" href="/collections/all">Shop Now</a>
            </div>
          </article>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Loved by Pet Parents",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Best sellers" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Loved by Pet Parents" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Our most-picked essentials for everyday comfort." },
    { "type": "collection", "id": "collection", "label": "Product collection" },
    { "type": "range", "id": "products_to_show", "label": "Products to show", "min": 2, "max": 8, "step": 1, "default": 4 },
    { "type": "text", "id": "view_all_text", "label": "View all text", "default": "View All" },
    { "type": "url", "id": "view_all_link", "label": "View all link" }
  ],
  "presets": [{ "name": "Loved by Pet Parents" }]
}
{% endschema %}
