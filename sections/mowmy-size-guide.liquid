<section class="mt-section mt-reveal"><div class="mt-page"><div class="mt-fit-guide"><div><span class="mt-eyebrow" style="color:#f5c542">Fit made simple</span><h2>{{ section.settings.heading }}</h2><p>{{ section.settings.text }}</p><div class="mt-fit-steps"><span>1. Neck</span><span>2. Chest</span><span>3. Back length</span></div></div><a class="mt-btn" style="background:#fff;color:#3f6f64" href="{{ section.settings.link | default: '/pages/size-guide' }}">{{ section.settings.label }}</a></div></div></section>
{% schema %}{"name":"Size guidance","settings":[{"type":"text","id":"heading","label":"Heading","default":"Find the Right Fit"},{"type":"textarea","id":"text","label":"Text","default":"Measure neck, chest, and back length before ordering for a comfortable, movement-friendly fit."},{"type":"text","id":"label","label":"Button label","default":"View Size Guide"},{"type":"url","id":"link","label":"Link"}],"presets":[{"name":"Size guidance"}]}{% endschema %}
