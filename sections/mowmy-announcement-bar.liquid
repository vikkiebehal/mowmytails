<div class="announcement" role="region" aria-label="Store announcements">
  <div class="announcement-track">
    {% for block in section.blocks %}
      <span class="announcement-item" {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
    {% else %}
      <span class="announcement-item">Free shipping above ₹999</span>
      <span class="announcement-item">Made with care in India</span>
      <span class="announcement-item">Easy returns</span>
      <span class="announcement-item">1 purchase = 1 bowl of love</span>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Announcement bar",
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Free shipping above ₹999" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement bar",
      "blocks": [
        { "type": "message", "settings": { "text": "Free shipping above ₹999" } },
        { "type": "message", "settings": { "text": "Made with care in India" } },
        { "type": "message", "settings": { "text": "Easy returns" } },
        { "type": "message", "settings": { "text": "1 purchase = 1 bowl of love" } }
      ]
    }
  ]
}
{% endschema %}
