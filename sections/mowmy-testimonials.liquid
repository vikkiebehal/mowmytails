<section class="mt-section mt-section--soft"><div class="mt-page"><div class="mt-section-head"><span class="mt-eyebrow">{{ section.settings.eyebrow }}</span><h2 class="mt-title">{{ section.settings.heading }}</h2><p class="mt-subtitle">{{ section.settings.text }}</p></div><div class="mt-testimonial-grid">{% for block in section.blocks %}<article class="mt-testimonial mt-reveal" {{ block.shopify_attributes }}><span class="mt-stars" aria-label="Five out of five stars">★★★★★</span><blockquote>“{{ block.settings.review }}”</blockquote><footer><strong>{{ block.settings.name }}</strong><span>Pet parent to {{ block.settings.pet }}</span></footer></article>{% endfor %}</div></div></section>
{% schema %}{"name":"Pet parent reviews","settings":[{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Happy tails, happy homes"},{"type":"text","id":"heading","label":"Heading","default":"Loved by Pet Parents"},{"type":"textarea","id":"text","label":"Text","default":"Real comfort, quality and joy in everyday moments."}],"blocks":[{"type":"review","name":"Review","settings":[{"type":"textarea","id":"review","label":"Review","default":"The quality feels beautiful and the fit was perfect from the first walk."},{"type":"text","id":"name","label":"Pet parent","default":"Aarushi"},{"type":"text","id":"pet","label":"Pet name","default":"Milo"}]}],"presets":[{"name":"Pet parent reviews","blocks":[{"type":"review"},{"type":"review","settings":{"review":"Our cat actually chose this bed over the sofa. It looks lovely in our home too.","name":"Naina","pet":"Miso"}},{"type":"review","settings":{"review":"Thoughtful packaging, fast delivery and a harness that finally feels secure without being bulky.","name":"Rohan","pet":"Bruno"}}]}]}{% endschema %}
