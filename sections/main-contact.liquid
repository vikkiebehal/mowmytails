<section><div class="mt-page-hero"><div class="mt-page"><span class="mt-eyebrow">We are here to help</span><h1>{{ section.settings.heading }}</h1><p>{{ section.settings.text }}</p></div></div><div class="mt-page mt-section"><div class="mt-contact-grid"><div><div class="mt-contact-card"><span class="mt-eyebrow">Email</span><h2>{{ section.settings.email }}</h2><p>For order, sizing and product questions.</p></div><div class="mt-contact-card" style="margin-top:14px"><span class="mt-eyebrow">Support hours</span><h2>{{ section.settings.hours }}</h2><p>{{ section.settings.response }}</p></div><div class="mt-accordion" style="margin-top:30px"><details><summary>When will my order ship?</summary><div class="mt-accordion__content">Most orders are dispatched within 1–3 business days.</div></details><details><summary>Can you help with sizing?</summary><div class="mt-accordion__content">Yes. Send us your pet's neck, chest and back measurements and our team will help.</div></details></div></div><div>{% form 'contact', class: 'mt-contact-form' %}{% if form.posted_successfully? %}<p class="mt-form-message mt-field--full">Thank you. We will be in touch soon.</p>{% endif %}{{ form.errors | default_errors }}<div class="mt-field"><label for="ContactName">Name</label><input id="ContactName" type="text" name="contact[name]" value="{{ form.name }}" required></div><div class="mt-field"><label for="ContactEmail">Email</label><input id="ContactEmail" type="email" name="contact[email]" value="{{ form.email }}" required></div><div class="mt-field mt-field--full"><label for="ContactPhone">Phone</label><input id="ContactPhone" type="tel" name="contact[phone]" value="{{ form.phone }}"></div><div class="mt-field mt-field--full"><label for="ContactMessage">How can we help?</label><textarea id="ContactMessage" name="contact[body]" required>{{ form.body }}</textarea></div><button class="mt-btn mt-btn--primary mt-field--full" type="submit">Send message</button>{% endform %}</div></div></div></section>
{% schema %}{"name":"Contact page","settings":[{"type":"text","id":"heading","label":"Heading","default":"Let’s Talk About Your Pet"},{"type":"textarea","id":"text","label":"Text","default":"Questions about an order, fit or product? Our care team would love to help."},{"type":"text","id":"email","label":"Email","default":"hello@mowmytails.com"},{"type":"text","id":"hours","label":"Support hours","default":"Monday–Saturday, 10am–6pm"},{"type":"text","id":"response","label":"Response note","default":"We usually reply within one business day."}]}{% endschema %}
