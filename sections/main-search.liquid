<section class="mt-search-results"><div class="mt-page"><div class="mt-section-head" style="text-align:center"><span class="mt-eyebrow">Find their next favorite</span><h1 class="mt-title">{% if search.performed %}Search results{% else %}Search Mowmy Tails{% endif %}</h1>{% if search.performed %}<p class="mt-subtitle" style="margin-inline:auto">{{ search.results_count }} results for “{{ search.terms }}”</p>{% endif %}</div><form class="mt-search-results__form" action="{{ routes.search_url }}" method="get" role="search"><input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search beds, harnesses, toys..."><input type="hidden" name="type" value="product"><button class="mt-btn mt-btn--primary" type="submit">Search</button></form>{% if search.performed %}{% paginate search.results by 16 %}{% if search.results_count > 0 %}<div class="mt-product-grid">{% for item in search.results %}{% if item.object_type == 'product' %}{% render 'product-card', product: item, show_rating: true %}{% endif %}{% endfor %}</div>{% if paginate.pages > 1 %}<nav class="mt-pagination">{{ paginate | default_pagination }}</nav>{% endif %}{% else %}<div class="mt-empty-state"><span class="mt-empty-state__mark">M</span><h2>No matches yet.</h2><p>Try a broader term or explore all of our pet essentials.</p><a class="mt-btn mt-btn--primary" href="{{ routes.all_products_collection_url }}">Shop all</a></div>{% endif %}{% endpaginate %}{% endif %}</div></section>
{% schema %}{"name":"Main search","settings":[]} {% endschema %}
