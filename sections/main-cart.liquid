<section class="mt-cart"><div class="mt-page"><div class="mt-section-head"><span class="mt-eyebrow">Your order</span><h1 class="mt-title">Shopping Bag</h1></div>{% if cart.item_count > 0 %}{% form 'cart', cart %}<div class="mt-cart-layout"><div>{% for item in cart.items %}<div class="mt-cart-item"><a href="{{ item.url }}">{{ item.image | image_url: width: 300 | image_tag: loading: 'lazy', alt: item.product.title }}</a><div class="mt-cart-item__details"><a href="{{ item.url }}"><strong>{{ item.product.title }}</strong></a>{% unless item.variant.title == 'Default Title' %}<small>{{ item.variant.title }}</small>{% endunless %}<div class="mt-quantity"><button type="button" data-quantity-change="-1">−</button><input type="number" name="updates[]" value="{{ item.quantity }}" min="0" aria-label="Quantity for {{ item.product.title }}"><button type="button" data-quantity-change="1">+</button></div><a class="mt-text-link" href="{{ item.url_to_remove }}">Remove</a></div><strong>{{ item.final_line_price | money }}</strong></div>{% endfor %}<button class="mt-btn mt-btn--secondary" type="submit" name="update">Update bag</button></div><aside class="mt-cart-summary"><h2>Order summary</h2><div class="mt-cart-summary__row"><span>Subtotal</span><strong>{{ cart.total_price | money }}</strong></div><p>Shipping and taxes calculated at checkout.</p><label for="CartNote">Order note</label><textarea class="mt-cart-note" id="CartNote" name="note" placeholder="Add delivery notes or a message">{{ cart.note }}</textarea><button class="mt-btn mt-btn--primary mt-btn--full" type="submit" name="checkout">Secure checkout</button><a class="mt-text-button" style="display:block;text-align:center;margin-top:14px" href="{{ routes.all_products_collection_url }}">Continue shopping</a></aside></div>{% endform %}{% else %}<div class="mt-empty-state"><span class="mt-empty-state__mark">M</span><h2>Your bag is waiting for a little joy.</h2><p>Discover thoughtful essentials for walks, naps, play and cuddles.</p><a class="mt-btn mt-btn--primary" href="{{ routes.all_products_collection_url }}">Explore the shop</a></div>{% endif %}</div></section>
{% schema %}{"name":"Main cart","settings":[]} {% endschema %}
