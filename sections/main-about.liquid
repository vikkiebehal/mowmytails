<section><div class="mt-page-hero"><div class="mt-page"><span class="mt-eyebrow">Our story</span><h1>{{ section.settings.heading }}</h1><p>{{ section.settings.intro }}</p></div></div><div class="mt-page mt-section"><div class="mt-about-grid"><div>{% if section.settings.image %}{{ section.settings.image | image_url: width: 1100 | image_tag: loading: 'eager', alt: section.settings.heading }}{% else %}<img src="{{ 'mt-photo-story-family.jpg' | asset_url }}" width="1200" height="900" alt="Pet parent sharing a loving moment with their dog" loading="eager">{% endif %}</div><div><span class="mt-eyebrow">Pets are family</span><h2 class="mt-title">{{ section.settings.story_heading }}</h2><p class="mt-subtitle">{{ section.settings.story_text }}</p><p>{{ section.settings.mission }}</p><a class="mt-btn mt-btn--primary" href="{{ routes.all_products_collection_url }}">Explore our collections</a></div></div><div class="mt-values-grid">{% for block in section.blocks %}<article class="mt-trust-item mt-reveal" {{ block.shopify_attributes }}><span class="mt-trust-icon">{{ forloop.index | prepend: '0' }}</span><h3>{{ block.settings.title }}</h3><p>{{ block.settings.text }}</p></article>{% endfor %}</div></div></section>
{% schema %}{"name":"About page","settings":[{"type":"text","id":"heading","label":"Heading","default":"Made for Pets Who Are Family"},{"type":"textarea","id":"intro","label":"Introduction","default":"We create thoughtful everyday essentials around the comfort, joy and unconditional love pets bring into our lives."},{"type":"image_picker","id":"image","label":"Lifestyle image"},{"type":"text","id":"story_heading","label":"Story heading","default":"Comfort, style and care in every little routine."},{"type":"textarea","id":"story_text","label":"Story text","default":"Mowmy Tails began with a simple belief: products for pets can be useful, beautiful and genuinely comfortable at the same time."},{"type":"textarea","id":"mission","label":"Mission","default":"Our mission is to curate pet-safe, dependable pieces that make walks easier, naps cozier and playtime happier, while helping spread care to pets who need it."}],"blocks":[{"type":"value","name":"Brand value","settings":[{"type":"text","id":"title","label":"Title","default":"Comfort first"},{"type":"textarea","id":"text","label":"Text","default":"Every product is considered through the way pets move, rest and play."}]}],"presets":[{"name":"About page","blocks":[{"type":"value"},{"type":"value","settings":{"title":"Curated quality","text":"We choose materials, details and construction with everyday durability in mind."}},{"type":"value","settings":{"title":"Love in action","text":"Each purchase helps us extend a bowl of love and care to more pets."}}]}]}{% endschema %}
