<section><div class="mt-page-hero"><div class="mt-page"><div class="mt-breadcrumbs"><a href="{{ routes.root_url }}">Home</a><span>/</span><span>Collections</span></div><span class="mt-eyebrow">Shop their world</span><h1>{{ section.settings.heading }}</h1><p>{{ section.settings.text }}</p></div></div><div class="mt-page mt-section"><div class="mt-list-collections">{% for collection in collections %}{% unless collection.handle == 'frontpage' %}<a class="mt-list-collection mt-reveal" href="{{ collection.url }}">{% if collection.featured_image %}{{ collection.featured_image | image_url: width: 900 | image_tag: loading: 'lazy', alt: collection.title }}{% else %}{{ 'collection-1' | placeholder_svg_tag: 'mt-placeholder' }}{% endif %}<h2>{{ collection.title }}</h2></a>{% endunless %}{% else %}<div class="mt-empty-state"><h2>Collections are coming soon.</h2><a class="mt-btn mt-btn--primary" href="{{ routes.all_products_collection_url }}">Shop all products</a></div>{% endfor %}</div></div></section>
{% schema %}{"name":"Collection list","settings":[{"type":"text","id":"heading","label":"Heading","default":"Explore Every Collection"},{"type":"textarea","id":"text","label":"Text","default":"Thoughtful essentials for walks, rest, play and all the moments you share."}]}{% endschema %}
