<section class="mt-section mt-reveal">
  <div class="mt-page">
    <div class="mt-story">
      <div class="mt-story-media">
        {% if section.settings.image %}
          {{ section.settings.image | image_url: width: 1100 | image_tag: loading: 'lazy', alt: section.settings.image_alt }}
        {% else %}
          <img src="{{ 'mt-photo-story-family.jpg' | asset_url }}" width="1200" height="900" alt="{{ section.settings.image_alt }}" loading="lazy">
        {% endif %}
      </div>
      <div class="mt-story-copy">
        <span class="mt-eyebrow">{{ section.settings.eyebrow }}</span>
        <h2 class="mt-title">{{ section.settings.heading }}</h2>
        <p>{{ section.settings.body }}</p>
        <a class="mt-btn mt-btn--primary" href="{{ section.settings.link | default: routes.root_url }}">{{ section.settings.button_text }}</a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand Story / Lifestyle",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Mowmy Tails story" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Made for Pets Who Are Family" },
    { "type": "textarea", "id": "body", "label": "Story", "default": "We believe the best pet products should feel good, work beautifully and fit naturally into the home you share. Every piece is chosen with comfort, style, care and love in mind." },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "Know Our Story" },
    { "type": "url", "id": "link", "label": "Link" },
    { "type": "image_picker", "id": "image", "label": "Lifestyle image" },
    { "type": "text", "id": "image_alt", "label": "Image alt text", "default": "Pet parent sharing a loving moment with their dog" }
  ],
  "presets": [{ "name": "Brand Story / Lifestyle" }]
}
{% endschema %}
