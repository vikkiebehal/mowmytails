{% doc %}
Renders the global cart drawer.
{% enddoc %}

<div class="mt-drawer mt-drawer--right" id="CartDrawer" hidden>
  <button class="mt-drawer__scrim" type="button" aria-label="Close cart" data-drawer-close></button>
  <aside class="mt-drawer__panel" aria-label="Shopping bag">
    <div class="mt-drawer__header"><div><span class="mt-eyebrow">Your order</span><h2>Shopping bag</h2></div><button class="mt-icon-button" type="button" aria-label="Close cart" data-drawer-close>×</button></div>
    <div class="mt-drawer__body">
      {% if cart.item_count > 0 %}
        {% for item in cart.items %}
          <div class="mt-mini-cart-item">
            <a href="{{ item.url }}">{{ item.image | image_url: width: 180 | image_tag: loading: 'lazy', alt: item.product.title }}</a>
            <div><a href="{{ item.url }}"><strong>{{ item.product.title }}</strong></a>{% unless item.variant.title == 'Default Title' %}<small>{{ item.variant.title }}</small>{% endunless %}<span>{{ item.final_line_price | money }}</span><div class="mt-quantity"><a href="{{ routes.cart_change_url }}?line={{ forloop.index }}&quantity={{ item.quantity | minus: 1 }}" aria-label="Decrease {{ item.product.title }} quantity">−</a><span>{{ item.quantity }}</span><a href="{{ routes.cart_change_url }}?line={{ forloop.index }}&quantity={{ item.quantity | plus: 1 }}" aria-label="Increase {{ item.product.title }} quantity">+</a></div><a class="mt-text-link" href="{{ item.url_to_remove }}">Remove</a></div>
          </div>
        {% endfor %}
      {% else %}
        <div class="mt-empty-state"><span class="mt-empty-state__mark">M</span><h3>Your bag is ready for something lovely.</h3><p>Explore comfort-first essentials for happier everyday routines.</p><a class="mt-btn mt-btn--primary" href="{{ routes.all_products_collection_url }}">Start shopping</a></div>
      {% endif %}
    </div>
    {% if cart.item_count > 0 %}<div class="mt-drawer__footer"><div class="mt-subtotal"><span>Subtotal</span><strong>{{ cart.total_price | money }}</strong></div><p>Taxes and shipping calculated at checkout.</p><a class="mt-btn mt-btn--primary mt-btn--full" href="{{ routes.cart_url }}">View bag & checkout</a><button class="mt-text-button" type="button" data-drawer-close>Continue shopping</button></div>{% endif %}
  </aside>
</div>
