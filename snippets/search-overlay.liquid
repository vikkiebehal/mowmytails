{% doc %}
Renders the global search overlay.
{% enddoc %}

<div class="mt-drawer mt-search-drawer" id="SearchDrawer" hidden>
  <button class="mt-drawer__scrim" type="button" aria-label="Close search" data-drawer-close></button>
  <aside class="mt-search-panel" aria-label="Search store">
    <div class="mt-search-panel__top"><span class="mt-eyebrow">Find their next favorite</span><button class="mt-icon-button" type="button" aria-label="Close search" data-drawer-close>×</button></div>
    <form class="mt-search-form" action="{{ routes.search_url }}" method="get" role="search">
      <label for="OverlaySearch">Search products</label>
      <div><input id="OverlaySearch" type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search beds, harnesses, toys..." autocomplete="off"><button class="mt-btn mt-btn--primary" type="submit">Search</button></div>
      <input type="hidden" name="type" value="product">
    </form>
    <div class="mt-search-suggestions"><span>Popular:</span><a href="{{ routes.collections_url }}/dogs">Dogs</a><a href="{{ routes.collections_url }}/cats">Cats</a><a href="{{ routes.collections_url }}/pet-apparel">Apparel</a><a href="{{ routes.collections_url }}/toys">Toys</a></div>
  </aside>
</div>
