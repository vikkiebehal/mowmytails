{% doc %}
Renders a homepage product collection grid.
@param {section} section - The parent section and its settings
{% enddoc %}

<section class="mt-section mt-products-section {% if section.settings.soft_background %}mt-section--soft{% endif %}">
  <div class="mt-page">
    <div class="mt-section-head mt-section-head--split">
      <div>
        <span class="mt-eyebrow">{{ section.settings.eyebrow }}</span>
        <h2 class="mt-title">{{ section.settings.heading }}</h2>
        <p class="mt-subtitle">{{ section.settings.text }}</p>
      </div>
      {% if section.settings.collection %}<a class="mt-btn mt-btn--secondary" href="{{ section.settings.collection.url }}">View all</a>{% endif %}
    </div>

    <div class="mt-product-grid">
      {% for product in section.settings.collection.products limit: section.settings.limit %}
        {% render 'product-card', product: product, show_rating: true %}
      {% else %}
        {% for i in (1..4) %}
          <article class="mt-product-card mt-reveal">
            <div class="mt-product-card__media">{{ 'product-' | append: i | placeholder_svg_tag: 'mt-placeholder' }}</div>
            <div class="mt-product-card__body">
              <span class="mt-stars">★★★★★ <small>(5.0)</small></span>
              <strong class="mt-product-card__title">Premium pet essential</strong>
              <div class="mt-price-row"><strong>{{ 129900 | money }}</strong></div>
              <a class="mt-btn mt-btn--small mt-btn--primary mt-btn--full" href="{{ routes.all_products_collection_url }}">Shop now</a>
            </div>
          </article>
        {% endfor %}
      {% endfor %}
    </div>
  </div>
</section>
